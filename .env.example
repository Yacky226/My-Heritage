# Pinata IPFS Configuration
# Generate a JWT at https://app.pinata.cloud/developers/api-keys
VITE_PINATA_JWT=

# Your Pinata dedicated gateway URL (or the default public gateway)
VITE_PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs/

# Frontend RPC endpoints used by Wagmi
VITE_HARDHAT_RPC_URL=http://127.0.0.1:8545
VITE_SEPOLIA_RPC_URL=
VITE_BASE_SEPOLIA_RPC_URL=
VITE_ARBITRUM_SEPOLIA_RPC_URL=
VITE_OPTIMISM_SEPOLIA_RPC_URL=

# AegisVault addresses per deployed network
# Keep empty until the contract has been deployed on that network.
VITE_AEGIS_VAULT_ADDRESS_SEPOLIA=
VITE_AEGIS_VAULT_ADDRESS_BASE_SEPOLIA=
VITE_AEGIS_VAULT_ADDRESS_ARBITRUM_SEPOLIA=
VITE_AEGIS_VAULT_ADDRESS_OPTIMISM_SEPOLIA=

# Backend deployment variables for Hardhat Ignition
# Never expose private keys with a VITE_ prefix.
SEPOLIA_RPC_URL=
SEPOLIA_PRIVATE_KEY=
BASE_SEPOLIA_RPC_URL=
BASE_SEPOLIA_PRIVATE_KEY=
ARBITRUM_SEPOLIA_RPC_URL=
ARBITRUM_SEPOLIA_PRIVATE_KEY=
OPTIMISM_SEPOLIA_RPC_URL=
OPTIMISM_SEPOLIA_PRIVATE_KEY=
